    <key name="tracked-apps" type="as">
      <default>[]</default>
      <summary>Tracked Applications</summary>
      <description>List of app IDs to auto minimize</description>
    </key>
    <key name="running-apps" type="as">
      <default>[]</default>
      <summary>Running Applications</summary>
